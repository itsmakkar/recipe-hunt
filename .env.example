# Recipe Hunter — copy variable names & values into Vercel:
# Project → Settings → Environment Variables (Production + Preview as needed)
# For local dev, copy this file to `.env.local` (Next.js loads it automatically).
# After deploy, open https://YOUR-APP.vercel.app/api/health — both flags should be true.

# --- Gemini (required for chat) ---
GEMINI_API_KEY=

# Optional: same role as GEMINI_API_KEY (only one needs to be set)
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=

# --- Firebase (required for uploads to persist on Vercel) ---
# Paste the entire service account JSON as a single line (from Firebase Console →
# Project settings → Service accounts → Generate new private key).
FIREBASE_SERVICE_ACCOUNT=

# Or: base64-encode the JSON file and put it here instead of FIREBASE_SERVICE_ACCOUNT
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Local development only — path to the downloaded JSON file (does not work on Vercel)
# FIREBASE_SERVICE_ACCOUNT_PATH=

# Optional overrides (usually inferred from the service account JSON)
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
